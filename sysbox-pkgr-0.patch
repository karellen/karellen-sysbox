diff --git a/k8s/scripts/crio-fetch.sh b/k8s/scripts/crio-fetch.sh
new file mode 100755
index 0000000..fee518e
--- /dev/null
+++ b/k8s/scripts/crio-fetch.sh
@@ -0,0 +1,53 @@
+#!/bin/bash
+
+#
+# Download pre-built patched CRI-O binaries from karellen-sysbox-crio releases.
+# Downloads ALL available micro versions for each minor.
+#
+# Usage: crio-fetch.sh <output-dir> <arch> <versions...>
+# Example: crio-fetch.sh bin/crio amd64 v1.32 v1.33 v1.34 v1.35
+#
+
+set -eEux
+set -o pipefail
+
+RESULTS_DIR="${1:?Usage: crio-fetch.sh <output-dir> <arch> <versions...>}"
+SYS_ARCH="${2:?Usage: crio-fetch.sh <output-dir> <arch> <versions...>}"
+shift 2
+
+REPO="karellen/karellen-sysbox-crio"
+
+ALL_RELEASES=$(gh release list -R "$REPO" --exclude-drafts --limit 1000 \
+    --json tagName --jq '.[].tagName')
+
+for minor in "$@"; do
+    MICRO_TAGS=$(echo "$ALL_RELEASES" | grep "^${minor}\." | sort -V)
+
+    if [ -z "$MICRO_TAGS" ]; then
+        echo "ERROR: No published releases found for ${minor} in ${REPO}" >&2
+        exit 1
+    fi
+
+    for tag in $MICRO_TAGS; do
+        if [ -f "${RESULTS_DIR}/${tag}/crio" ] && [ -f "${RESULTS_DIR}/${tag}/pinns" ] && [ -f "${RESULTS_DIR}/${tag}/crictl" ]; then
+            echo "Skip fetching CRI-O ${tag} -- binaries already present"
+            continue
+        fi
+
+        echo "Fetching CRI-O ${tag} patched binaries ..."
+
+        _tmpdir=$(mktemp -d)
+        trap "rm -rf '$_tmpdir'" EXIT
+
+        gh release download "$tag" -R "$REPO" \
+            --pattern "crio-${tag}-${SYS_ARCH}.tar.gz" \
+            --dir "$_tmpdir"
+
+        mkdir -p "${RESULTS_DIR}/${tag}"
+        tar -xzf "${_tmpdir}/crio-${tag}-${SYS_ARCH}.tar.gz" -C "${RESULTS_DIR}/${tag}"
+        rm -rf "$_tmpdir"
+        trap - EXIT
+
+        echo "Fetched CRI-O ${tag} (${SYS_ARCH}) -> ${RESULTS_DIR}/${tag}/"
+    done
+done
